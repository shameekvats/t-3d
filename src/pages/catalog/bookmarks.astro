---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';
import { Image } from 'astro:assets';

import thumb from '~/assets/images/Gallery/bookmarks/IMG_5479.jpg';
import img1 from '~/assets/images/Gallery/bookmarks/Cat_Sticker_Bookmark.jpeg';
import img2 from '~/assets/images/Gallery/bookmarks/Nish.jpg';
import img3 from '~/assets/images/Gallery/bookmarks/IMG_5477.jpg';
import img4 from '~/assets/images/Gallery/bookmarks/IMG_5478.jpg';
import img5 from '~/assets/images/Gallery/bookmarks/1_IMG_1438.jpg';
import img6 from '~/assets/images/Gallery/bookmarks/IMG_5480.jpg';

const metadata = { title: 'Bookmarks — tattva-3d' };

const items = [
  { image: thumb, title: 'Image Bookmark', description: 'Turn your photos into bookmarks', price: '€10' },
  { image: img1,  title: 'Cat Sticker Bookmark', description: 'Playful animal themed design', price: '€7.50' },
  { image: img2,  title: 'Name Bookmark', description: 'Personalized with your name', price: '€5' },
  { image: img3,  title: 'Logo Bookmark', description: 'Business or brand logos', price: '€7.50' },
  { image: img4,  title: 'Quote Bookmark', description: 'Featuring inspirational quotes', price: '€7.50' },
  { image: img5,  title: 'Personalized Bookmark', description: 'Custom text and designs', price: '€7.50' },
  { image: img6,  title: 'Gift Bookmark', description: 'Perfect for book lovers', price: '€10' },
];
---

<Layout metadata={metadata}>
  <section class="pt-24 pb-12 bg-gradient-to-b from-primary/10 to-transparent dark:from-primary/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="mb-6 text-sm">
        <a href={getPermalink('/')} class="text-gray-600 dark:text-gray-400 hover:text-primary">Home</a>
        <span class="mx-2 text-gray-400">/</span>
        <a href={getPermalink('/catalog')} class="text-gray-600 dark:text-gray-400 hover:text-primary">Catalog</a>
        <span class="mx-2 text-gray-400">/</span>
        <span class="text-gray-900 dark:text-gray-100 font-semibold">Bookmarks</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="text-6xl">📖</div>
            <div>
              <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100">Bookmarks</h1>
              <p class="text-xl text-gray-600 dark:text-gray-400 mt-2">Unique glow-in-the-dark bookmarks, fully personalised</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 mb-6">
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">🌙</span><span class="text-sm font-medium">Glow in the Dark</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">🎨</span><span class="text-sm font-medium">Custom Designs</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">📸</span><span class="text-sm font-medium">Photo to Bookmark</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">💝</span><span class="text-sm font-medium">Personal Designs</span>
            </div>
          </div>

          <p class="text-lg text-gray-600 dark:text-gray-400">
            Make every page special. Choose a name, quote, or image and we'll print it in glowing filament — so your bookmark looks great on the shelf and glows softly when the lights go out. Have a unique idea? We're happy to discuss personal and custom designs.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 border border-gray-100 dark:border-slate-700">
          <div class="pb-6 mb-6 border-b border-gray-200 dark:border-slate-700">
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-4 text-center">Pricing</p>
            <div class="space-y-3">
              <div class="flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-slate-700/50 rounded-lg">
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Basic / Single Color</span>
                <span class="text-2xl font-extrabold text-primary">€5</span>
              </div>
              <div class="flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-slate-700/50 rounded-lg">
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">2-Color</span>
                <span class="text-2xl font-extrabold text-primary">€7.50</span>
              </div>
              <div class="flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-slate-700/50 rounded-lg">
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Photo Bookmark</span>
                <span class="text-2xl font-extrabold text-primary">€10</span>
              </div>
            </div>
          </div>

          <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/50 rounded-lg p-4 mb-4">
            <div class="flex items-start gap-2">
              <span class="text-lg mt-0.5">🌙</span>
              <div>
                <p class="text-xs font-semibold text-amber-800 dark:text-amber-300 mb-0.5">Glow in the Dark</p>
                <p class="text-xs text-amber-700 dark:text-amber-400">All bookmarks are made with phosphorescent filament — they absorb light and glow softly in the dark.</p>
              </div>
            </div>
          </div>

          <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700/50 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-600 dark:text-blue-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
              </svg>
              <div>
                <p class="text-xs font-semibold text-blue-800 dark:text-blue-300 mb-0.5">Custom & Personal Designs</p>
                <p class="text-xs text-blue-700 dark:text-blue-400">Have something specific in mind? Reach out and we'll work through the details together.</p>
              </div>
            </div>
          </div>

          <a
            href="/order?product=bookmarks"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-105 hover:shadow-lg mb-3"
          >
            Order Your Bookmark — From €5
          </a>

          <p class="text-center text-sm text-gray-500 dark:text-gray-400">
            Questions? <a href="mailto:t-3d@ik.me" class="text-primary hover:underline font-medium">t-3d@ik.me</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8">Examples</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {items.map((item) => (
          <div class="group relative bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300">
            <div class="relative aspect-square overflow-hidden bg-gray-100 dark:bg-slate-700">
              <Image
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                widths={[400, 768]}
                sizes="(max-width: 768px) 100vw, 400px"
              />
              {item.price && (
                <span class="absolute bottom-2 left-2 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded-full">
                  {item.price}
                </span>
              )}
            </div>
            <div class="p-4">
              <h3 class="font-bold text-lg text-gray-900 dark:text-gray-100 mb-1">{item.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-gradient-to-r from-primary/10 to-secondary/10 dark:from-primary/20 dark:to-secondary/20 rounded-2xl p-10 text-center">
        <h3 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">Design Your Custom Bookmark</h3>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-6 max-w-2xl mx-auto">
          A name, quote, photo, or your own design — we'll make it glow.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/order?product=bookmarks"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-105"
          >
            <span>Order Now — From €5</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a
            href={getPermalink('/catalog')}
            class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 dark:border-gray-600 hover:border-primary dark:hover:border-primary text-gray-900 dark:text-gray-100 font-bold py-4 px-8 rounded-lg transition-all duration-300"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            <span>Back to Catalog</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
