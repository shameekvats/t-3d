---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';
import { Image } from 'astro:assets';

import thumb from '~/assets/images/Gallery/cookie_cutter/1_IMG_4620.jpg';
import img1 from '~/assets/images/Gallery/cookie_cutter/cookie_cutter1.png';
import img2 from '~/assets/images/Gallery/cookie_cutter/IMG_4587.jpg';
import img3 from '~/assets/images/Gallery/cookie_cutter/IMG_4604.jpg';
import img4 from '~/assets/images/Gallery/cookie_cutter/IMG_9169.JPG';

const metadata = { title: 'Cookie Cutters — tattva-3d' };

const items = [
  { image: thumb, title: 'Custom Shape Cutter', description: 'Any design you can imagine' },
  { image: img1,  title: 'Baked Cookie with Cutter', description: 'Client result — before and after' },
  { image: img2,  title: 'Themed Cutter', description: 'Holidays and special occasions' },
  { image: img3,  title: 'Custom Design Cutter', description: 'Unique shapes and patterns' },
  { image: img4,  title: 'Cookie Dough', description: 'Fresh cut dough ready for baking' },
];
---

<Layout metadata={metadata}>
  <section class="pt-24 pb-12 bg-gradient-to-b from-primary/10 to-transparent dark:from-primary/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="mb-6 text-sm">
        <a href={getPermalink('/')} class="text-gray-600 dark:text-gray-400 hover:text-primary">Home</a>
        <span class="mx-2 text-gray-400">/</span>
        <a href={getPermalink('/catalog')} class="text-gray-600 dark:text-gray-400 hover:text-primary">Catalog</a>
        <span class="mx-2 text-gray-400">/</span>
        <span class="text-gray-900 dark:text-gray-100 font-semibold">Cookie Cutters</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="text-6xl">🍪</div>
            <div>
              <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100">Cookie Cutters</h1>
              <p class="text-xl text-gray-600 dark:text-gray-400 mt-2">Food-safe custom cookie cutters in any shape imaginable</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 mb-6">
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">✅</span><span class="text-sm font-medium">Food-Safe PLA</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">🎨</span><span class="text-sm font-medium">Any Shape</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">💡</span><span class="text-sm font-medium">Custom Design</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <span class="text-2xl">🎂</span><span class="text-sm font-medium">Baking Ready</span>
            </div>
          </div>

          <p class="text-lg text-gray-600 dark:text-gray-400">
            Create unique cookies for themed parties, holidays, business events, or gifts. Choose a shape from our catalog, send a screenshot of a design you love, or share a hi-res photo — we'll turn it into a precision cutter made from food-safe materials.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 border border-gray-100 dark:border-slate-700">
          <div class="pb-6 mb-6 border-b border-gray-200 dark:border-slate-700">
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-4 text-center">Pricing</p>
            <div class="space-y-3">
              <div class="flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-slate-700/50 rounded-lg">
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Per Piece</span>
                <span class="text-2xl font-extrabold text-primary">€5</span>
              </div>
            </div>
          </div>

          <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/50 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-amber-600 dark:text-amber-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
              <div>
                <p class="text-xs font-semibold text-amber-800 dark:text-amber-300 mb-0.5">Minimum Order — 5 Pieces</p>
                <p class="text-xs text-amber-700 dark:text-amber-400">Minimum order is 5 pieces (€25 total). Choose from our catalog, send a screenshot, or share a hi-res photo of your design.</p>
              </div>
            </div>
          </div>

          <a
            href="/order?product=cookie-cutters"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-105 hover:shadow-lg mb-3"
          >
            Order Cookie Cutters — €5 / piece
          </a>

          <p class="text-center text-sm text-gray-500 dark:text-gray-400">
            Questions? <a href="mailto:t-3d@ik.me" class="text-primary hover:underline font-medium">t-3d@ik.me</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8">Examples</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {items.map((item) => (
          <div class="group relative bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300">
            <div class="aspect-square overflow-hidden bg-gray-100 dark:bg-slate-700">
              <Image
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                widths={[400, 768]}
                sizes="(max-width: 768px) 100vw, 400px"
              />
            </div>
            <div class="p-4">
              <h3 class="font-bold text-lg text-gray-900 dark:text-gray-100 mb-1">{item.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-gradient-to-r from-primary/10 to-secondary/10 dark:from-primary/20 dark:to-secondary/20 rounded-2xl p-10 text-center">
        <h3 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">Need Custom Cookie Cutters?</h3>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-6 max-w-2xl mx-auto">
          Tell us the shape — logos, characters, themes, or custom designs. Min. 5 pieces per order.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/order?product=cookie-cutters"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-105"
          >
            <span>Order Now — €5 / piece</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a
            href={getPermalink('/catalog')}
            class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 dark:border-gray-600 hover:border-primary dark:hover:border-primary text-gray-900 dark:text-gray-100 font-bold py-4 px-8 rounded-lg transition-all duration-300"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            <span>Back to Catalog</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
