---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { useTranslations } from '~/i18n/utils';

const lang = 'fr';
const t = useTranslations(lang);

const metadata = { title: 'Contact — tattva-3d' };
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">{t('contact.title')}</Fragment>
    <Fragment slot="subtitle">{t('contact.subtitle')}</Fragment>
  </Hero>

  <section class="py-16 md:py-20 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold mb-4">{t('contact.form.title')}</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">{t('contact.form.subtitle')}</p>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg p-8">
        <form action="https://formspree.io/f/mzzazwro" method="POST" id="contactForm">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{t('contact.form.name')} *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white" placeholder={t('contact.form.namePlaceholder')} />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{t('contact.form.email')} *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white" placeholder={t('contact.form.emailPlaceholder')} />
            </div>
          </div>

          <div class="mb-6">
            <label for="subject" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{t('contact.form.type')} *</label>
            <select id="subject" name="subject" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white">
              <option value="">{t('contact.form.typePlaceholder')}</option>
              <option value="Custom 3d Print">{t('contact.form.opt.custom')}</option>
              <option value="Design Help">{t('contact.form.opt.design')}</option>
              <option value="Quote Request">{t('contact.form.opt.quote')}</option>
              <option value="General Question">{t('contact.form.opt.general')}</option>
            </select>
          </div>

          <div class="mb-6">
            <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{t('contact.form.message')} *</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white resize-vertical" placeholder={t('contact.form.messagePlaceholder')}></textarea>
          </div>

          <div class="text-center">
            <button type="submit" class="inline-flex items-center px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-200 shadow-lg hover:shadow-xl disabled:opacity-50" id="submitButton">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
              </svg>
              <span id="buttonText">{t('contact.form.submit')}</span>
            </button>
          </div>

          <div id="successMessage" class="hidden mt-6 p-4 bg-green-50 dark:bg-green-900 border border-green-200 dark:border-green-700 rounded-lg">
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <p class="text-green-700 dark:text-green-300">{t('contact.form.success')}</p>
            </div>
          </div>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-600">
          <div class="bg-blue-50 dark:bg-blue-900 rounded-lg p-4 mb-4">
            <h3 class="text-lg font-medium text-blue-900 dark:text-blue-100 mb-2">📁 {t('contact.files.title')}</h3>
            <p class="text-sm text-blue-700 dark:text-blue-300">{t('contact.files.subtitle')}</p>
            <ul class="text-sm text-blue-700 dark:text-blue-300 mt-2 space-y-1">
              <li>• <strong>{t('contact.files.email')}</strong></li>
              <li>• <strong>{t('contact.files.cloud')}</strong></li>
              <li>• <strong>{t('contact.files.mention')}</strong></li>
            </ul>
          </div>
        </div>

        <div class="text-center">
          <p class="text-gray-600 dark:text-gray-300">
            {t('contact.direct')}
            <a href="mailto:t-3d@ik.me" class="text-blue-600 hover:text-blue-800 font-medium">t-3d@ik.me</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
  const successMessage = document.getElementById('successMessage');
  const submitButton = document.getElementById('submitButton') as HTMLButtonElement | null;
  const buttonText = document.getElementById('buttonText');

  contactForm?.addEventListener('submit', async function (e) {
    e.preventDefault();
    if (!submitButton || !buttonText) return;

    submitButton.disabled = true;
    buttonText.textContent = 'Envoi en cours...';
    successMessage?.classList.add('hidden');

    try {
      const response = await fetch((contactForm as HTMLFormElement).action, {
        method: 'POST',
        body: new FormData(contactForm as HTMLFormElement),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        successMessage?.classList.remove('hidden');
        (contactForm as HTMLFormElement).reset();
        successMessage?.scrollIntoView({ behavior: 'smooth' });
      } else {
        alert('Désolé, une erreur s\'est produite. Veuillez réessayer.');
      }
    } catch {
      alert('Désolé, une erreur s\'est produite. Veuillez réessayer.');
    }

    submitButton.disabled = false;
    buttonText.textContent = 'Envoyer le message';
  });
});
</script>
