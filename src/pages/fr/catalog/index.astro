---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Image } from 'astro:assets';
import CategoryGridThumbnail from '~/components/CategoryGridThumbnail.astro';
import { useTranslations, getLocalizedUrl } from '~/i18n/utils';

import keychainImg from '~/assets/images/Gallery/keychain/1_keychain.JPG';
import keychain1 from '~/assets/images/Gallery/keychain/f43fe093-2fd4-4eda-8315-e32f757ec098.JPG';
import keychain2 from '~/assets/images/Gallery/keychain/IMG_4973.jpg';
import keychain3 from '~/assets/images/Gallery/keychain/IMG_5103.jpg';
import keychain4 from '~/assets/images/Gallery/keychain/PHOTO-2025-09-21-11-54-36.jpg';
import bookmarkImg from '~/assets/images/Gallery/bookmarks/IMG_5479.jpg';
import bookmark1 from '~/assets/images/Gallery/bookmarks/IMG_5479.jpg';
import bookmark2 from '~/assets/images/Gallery/bookmarks/Cat_Sticker_Bookmark.jpeg';
import bookmark3 from '~/assets/images/Gallery/bookmarks/1_IMG_1438.jpg';
import bookmark4 from '~/assets/images/Gallery/bookmarks/Nish.jpg';
import cookieImg from '~/assets/images/Gallery/cookie_cutter/1_IMG_4620.jpg';
import mapImg from '~/assets/images/Gallery/maps_cityscapes/1_Lux_Ville.jpg';
import glowImg from '~/assets/images/Gallery/3d_photo/1_A_IMG_4199.jpg';
import glow1 from '~/assets/images/Gallery/3d_photo/1_A_IMG_4199.jpg';
import glow2 from '~/assets/images/Gallery/3d_photo/B_IMG_4201.JPG';
import electronicsImg from '~/assets/images/Gallery/electronics/iPhoneDock.jpg';
import electronics1 from '~/assets/images/Gallery/electronics/iPhoneDock.jpg';
import electronics2 from '~/assets/images/Gallery/electronics/clock.jpg';
import electronics3 from '~/assets/images/Gallery/electronics/lightbox.jpg';
import electronics4 from '~/assets/images/Gallery/electronics/mouse.JPG';
import lampsImg from '~/assets/images/Gallery/lamps/mini-lamps.jpg';
import magnetImg from '~/assets/images/Gallery/fridge_magnets/1_IMG_4307.jpg';

const lang = 'fr';
const t = useTranslations(lang);

const metadata = {
  title: 'Catalogue — tattva-3d | Impressions 3D au Luxembourg',
  description: "Découvrez le catalogue tattva-3d d'impressions 3D personnalisées au Luxembourg — porte-clés, marque-pages, lampes, cartes et plus encore.",
};

const categories = [
  { id: 'lamps', title: t('category.lamps.title'), icon: '💡', description: t('category.lamps.description'), image: lampsImg, priceFrom: 10, slug: 'lamps' },
  { id: 'keychains', title: t('category.keychains.title'), icon: '🔑', description: t('category.keychains.description'), image: keychainImg, gridImages: [keychain1, keychain2, keychain3, keychain4], priceFrom: 5, slug: 'keychains' },
  { id: 'bookmarks', title: t('category.bookmarks.title'), icon: '📖', description: t('category.bookmarks.description'), image: bookmarkImg, gridImages: [bookmark1, bookmark2, bookmark3, bookmark4], priceFrom: 5, slug: 'bookmarks' },
  { id: 'electronics', title: t('category.electronics.title'), icon: '⚙️', description: t('category.electronics.description'), image: electronicsImg, gridImages: [electronics1, electronics2, electronics3, electronics4], priceFrom: 10, slug: 'electronics' },
  { id: 'maps', title: t('category.maps.title'), icon: '🗺️', description: t('category.maps.description'), image: mapImg, priceFrom: 20, slug: 'maps-cityscapes' },
  { id: 'glow-photos', title: t('category.glowphotos.title'), icon: '✨', description: t('category.glowphotos.description'), image: glowImg, gridImages: [glow1, glow2], priceFrom: 15, slug: 'glow-photos' },
  { id: 'fridge-magnets', title: t('category.magnets.title'), icon: '🧲', description: t('category.magnets.description'), image: magnetImg, priceFrom: 7.5, slug: 'fridge-magnets' },
  { id: 'cookie-cutters', title: t('category.cookies.title'), icon: '🍪', description: t('category.cookies.description'), image: cookieImg, priceFrom: 5, slug: 'cookie-cutters' },
];
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">{t('portfolio.title')}</Fragment>
    <Fragment slot="subtitle">{t('portfolio.subtitle')}</Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent dark:from-primary/20"></div>
    </Fragment>
  </Hero>

  <section class="py-16 md:py-20 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {categories.map((category) => (
          <a
            href={getLocalizedUrl(`/catalog/${category.slug}`, lang)}
            class="category-card group block bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2"
          >
            <div class="relative aspect-[4/3]">
              {category.gridImages ? (
                <CategoryGridThumbnail images={category.gridImages} title={category.title} columns={2} />
              ) : (
                <div class="relative aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-slate-700">
                  <Image
                    src={category.image}
                    alt={category.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    widths={[400, 768]}
                    sizes="(max-width: 768px) 100vw, 400px"
                  />
                </div>
              )}
              {category.priceFrom && (
                <div class="absolute top-3 right-3 z-10 bg-primary text-white text-sm font-bold px-3 py-2 rounded-full shadow-lg">
                  {t('portfolio.priceFrom')} {category.priceFrom} €
                </div>
              )}
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-bold mb-3 text-gray-900 dark:text-gray-100 group-hover:text-primary transition-colors">
                {category.title}
              </h3>
              <p class="text-gray-600 dark:text-gray-400 mb-4 line-clamp-2">{category.description}</p>
              <div class="flex items-center text-primary font-semibold group-hover:gap-3 transition-all">
                <span>{t('portfolio.viewGallery')}</span>
                <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-20 text-center bg-gradient-to-r from-primary/10 to-secondary/10 dark:from-primary/20 dark:to-secondary/20 rounded-2xl p-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-gray-100">{t('portfolio.cta.title')}</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">{t('portfolio.cta.subtitle')}</p>
        <a
          href={getLocalizedUrl('/contact', lang)}
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-105 hover:shadow-xl"
        >
          <span>{t('portfolio.cta.button')}</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .category-card { cursor: pointer; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
