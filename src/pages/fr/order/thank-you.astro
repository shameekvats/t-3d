---
import Layout from '~/layouts/PageLayout.astro';
import { useTranslations, getLocalizedUrl } from '~/i18n/utils';

const lang = 'fr';
const t = useTranslations(lang);

const metadata = {
  title: 'Commande Reçue — tattva-3d',
  description: 'Votre demande de commande a bien été reçue.',
};
---

<Layout metadata={metadata}>
  <section class="py-20 md:py-32 bg-gradient-to-br from-white to-gray-50 dark:from-slate-900 dark:to-slate-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="mb-8">
        <div class="w-24 h-24 mx-auto bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
          <svg class="w-12 h-12 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 dark:text-gray-100">{t('order.thankyou.title')}</h1>

      <div class="max-w-2xl mx-auto mb-8">
        <p class="text-xl text-gray-600 dark:text-gray-300">{t('order.thankyou.message')}</p>
      </div>

      <div class="max-w-2xl mx-auto mb-12">
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg p-8 text-left">
          <h2 class="text-2xl font-semibold mb-6 text-gray-900 dark:text-gray-100 text-center">{t('order.thankyou.next.title')}</h2>
          <ul class="space-y-4">
            {[
              { n: 1, title: t('order.thankyou.next.s1.title'), desc: t('order.thankyou.next.s1.desc') },
              { n: 2, title: t('order.thankyou.next.s2.title'), desc: t('order.thankyou.next.s2.desc') },
              { n: 3, title: t('order.thankyou.next.s3.title'), desc: t('order.thankyou.next.s3.desc') },
            ].map(({ n, title, desc }) => (
              <li class="flex items-start">
                <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center mr-4">
                  <span class="text-primary font-semibold">{n}</span>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1">{title}</h3>
                  <p class="text-gray-600 dark:text-gray-400">{desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="max-w-2xl mx-auto mb-12 p-6 bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-500 rounded-lg text-left">
        <h3 class="font-semibold text-blue-900 dark:text-blue-300 mb-2 flex items-center">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
          {t('order.thankyou.note.title')}
        </h3>
        <p class="text-blue-800 dark:text-blue-200">{t('order.thankyou.note.text')}</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={getLocalizedUrl('/', lang)}
          class="inline-flex items-center justify-center px-8 py-3 rounded-lg bg-primary hover:bg-primary-dark text-white font-semibold transition-all duration-300 transform hover:scale-105 hover:shadow-lg"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          {t('order.thankyou.backHome')}
        </a>
        <a
          href={getLocalizedUrl('/catalog', lang)}
          class="inline-flex items-center justify-center px-8 py-3 rounded-lg bg-gray-200 hover:bg-gray-300 dark:bg-slate-700 dark:hover:bg-slate-600 text-gray-900 dark:text-gray-100 font-semibold transition-all duration-300"
        >
          {t('order.thankyou.viewWork')}
        </a>
      </div>
    </div>
  </section>
</Layout>
