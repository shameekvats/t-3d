---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import { useTranslations, getLocalizedUrl } from '~/i18n/utils';

import thumb from '~/assets/images/Gallery/3d_photo/1_A_IMG_4199.jpg';
import img1 from '~/assets/images/Gallery/3d_photo/B_IMG_4201.JPG';
import img2 from '~/assets/images/Gallery/3d_photo/A_Filament_Painting_Glow.jpg';
import img3 from '~/assets/images/Gallery/3d_photo/B_Filament_Painting.jpg';
import img4 from '~/assets/images/Gallery/3d_photo/IMG_4326.jpg';

const lang = 'fr';
const t = useTranslations(lang);

const metadata = { title: 'Photos 3D Lumineuses — tattva-3d' };

const items = [
  { image: thumb, title: t('glow.i1.title'), description: t('glow.i1.desc') },
  { image: img1,  title: t('glow.i2.title'), description: t('glow.i2.desc') },
  { image: img2,  title: t('glow.i3.title'), description: t('glow.i3.desc') },
  { image: img3,  title: t('glow.i4.title'), description: t('glow.i4.desc') },
  { image: img4,  title: t('glow.i5.title'), description: t('glow.i5.desc') },
];
---

<Layout metadata={metadata}>
  <section class="pt-24 pb-12 bg-gradient-to-b from-primary/10 to-transparent dark:from-primary/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="mb-6 text-sm">
        <a href={getLocalizedUrl('/', lang)} class="text-gray-600 dark:text-gray-400 hover:text-primary">{t('portfolio.breadcrumb.home')}</a>
        <span class="mx-2 text-gray-400">/</span>
        <a href={getLocalizedUrl('/portfolio', lang)} class="text-gray-600 dark:text-gray-400 hover:text-primary">{t('portfolio.breadcrumb.portfolio')}</a>
        <span class="mx-2 text-gray-400">/</span>
        <span class="text-gray-900 dark:text-gray-100 font-semibold">{t('glow.title')}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <!-- Left: title, features, description -->
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="text-6xl">✨</div>
            <div>
              <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100">{t('glow.title')}</h1>
              <p class="text-xl text-gray-600 dark:text-gray-400 mt-2">{t('glow.subtitle')}</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 mb-6">
            {[['✨', t('glow.f1')], ['📸', t('glow.f2')], ['🎨', t('glow.f3')], ['🌟', t('glow.f4')]].map(([icon, label]) => (
              <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
                <span class="text-2xl">{icon}</span><span class="text-sm font-medium">{label}</span>
              </div>
            ))}
          </div>

          <p class="text-lg text-gray-600 dark:text-gray-400">{t('glow.description')}</p>
        </div>

        <!-- Right: product info card -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 border border-gray-100 dark:border-slate-700">
          <!-- Price -->
          <div class="text-center pb-6 mb-6 border-b border-gray-200 dark:border-slate-700">
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-1">{t('glow.price.label')}</p>
            <p class="text-6xl font-extrabold text-primary">{t('glow.price')}</p>
          </div>

          <!-- Specs -->
          <div class="space-y-3 mb-6">
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-slate-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">{t('glow.spec.size.label')}</span>
              <span class="font-semibold text-gray-900 dark:text-gray-100">{t('glow.spec.size')}</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-slate-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">{t('glow.spec.color.label')}</span>
              <span class="inline-flex items-center gap-1.5 font-semibold text-gray-900 dark:text-gray-100">
                <span class="w-3 h-3 rounded-full bg-gray-800 dark:bg-gray-300 ring-1 ring-gray-300 dark:ring-slate-500"></span>
                {t('glow.spec.color')}
              </span>
            </div>
          </div>

          <!-- Photo required note -->
          <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/50 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-amber-600 dark:text-amber-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
              <div>
                <p class="text-xs font-semibold text-amber-800 dark:text-amber-300 mb-0.5">{t('glow.spec.photo.label')}</p>
                <p class="text-xs text-amber-700 dark:text-amber-400">{t('glow.spec.photo.note')}</p>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <a
            href={getLocalizedUrl('/order', lang) + '?product=glow-photos'}
            class="block w-full text-center bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-105 hover:shadow-lg mb-3"
          >
            {t('glow.order.cta')}
          </a>

          <p class="text-center text-sm text-gray-500 dark:text-gray-400">
            {t('order.contact.note')} <a href="mailto:t-3d@ik.me" class="text-primary hover:underline font-medium">t-3d@ik.me</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8">{t('portfolio.examples')}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {items.map((item) => (
          <div class="group relative bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300">
            <div class="aspect-square overflow-hidden bg-gray-100 dark:bg-slate-700">
              <Image src={item.image} alt={item.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" widths={[400, 768]} sizes="(max-width: 768px) 100vw, 400px" />
            </div>
            <div class="p-4">
              <h3 class="font-bold text-lg text-gray-900 dark:text-gray-100 mb-1">{item.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="bg-gradient-to-r from-primary/10 to-secondary/10 dark:from-primary/20 dark:to-secondary/20 rounded-2xl p-10 text-center">
        <h3 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">{t('glow.cta.title')}</h3>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-6 max-w-2xl mx-auto">{t('glow.cta.subtitle')}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={getLocalizedUrl('/order', lang) + '?product=glow-photos'} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-105">
            <span>{t('glow.order.cta')}</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href={getLocalizedUrl('/portfolio', lang)} class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 dark:border-gray-600 hover:border-primary text-gray-900 dark:text-gray-100 font-bold py-4 px-8 rounded-lg transition-all duration-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            <span>{t('portfolio.backToPortfolio')}</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
