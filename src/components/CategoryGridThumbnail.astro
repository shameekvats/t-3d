---
import { Image } from 'astro:assets';

interface Props {
  images: any[];
  title: string;
  columns?: number;
}

const { images, title, columns = 2 } = Astro.props;
const gridImages = images || [];

// Determine grid layout based on image count and columns
const getGridClass = () => {
  if (gridImages.length === 1) return 'grid-cols-1';
  if (gridImages.length === 2) return 'grid-cols-2';
  if (gridImages.length === 4) {
    return columns === 2 ? 'grid-cols-2' : 'grid-cols-2';
  }
  return 'grid-cols-2';
};
---

<div class="relative w-full h-full bg-gray-100 dark:bg-slate-700 overflow-hidden">
  {gridImages.length === 1 ? (
    <!-- Single Image -->
    <Image 
      src={gridImages[0]}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
      widths={[400, 768]}
      sizes="(max-width: 768px) 100vw, 400px"
    />
  ) : (
    <!-- Grid Layout -->
    <div class={`grid ${getGridClass()} gap-0.5 w-full h-full`}>
      {gridImages.map((img, index) => (
        <div key={index} class="relative overflow-hidden bg-gray-200 dark:bg-slate-600">
          <Image 
            src={img}
            alt={`${title} - ${index + 1}`}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            widths={[200, 400]}
            sizes="(max-width: 768px) 50vw, 200px"
          />
        </div>
      ))}
    </div>
  )}
</div>
